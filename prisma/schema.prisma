generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AIGeneratedContent {
  id              BigInt     @id @default(autoincrement())
  userId          BigInt     @map("user_id")
  businessId      BigInt?    @map("business_id")
  contentType     String?    @map("content_type")
  inputData       String?    @map("input_data")
  generatedOutput String?    @map("generated_output")
  isSaved         Boolean?   @default(false) @map("is_saved")
  metadata        Json?
  createdAt       DateTime?  @default(now()) @map("created_at")
  modelId         BigInt?    @map("model_id")
  promptId        BigInt?    @map("prompt_id")
  status          String?    @default("completed")
  inputTokens     Int?       @default(0) @map("input_tokens")
  outputTokens    Int?       @default(0) @map("output_tokens")
  responseTimeMs  Int?       @map("response_time_ms")
  mediaId         BigInt?    @map("media_id")
  media           MediaFile? @relation(fields: [mediaId], references: [id])
  model           AIModel?   @relation(fields: [modelId], references: [id])
  prompt          AIPrompt?  @relation(fields: [promptId], references: [id])
  user            User       @relation(fields: [userId], references: [id])

  @@map("ai_generated_content")
}

model AIModel {
  id                BigInt               @id @default(autoincrement())
  modelKey          String               @unique @map("model_key")
  provider          String
  modelType         String               @map("model_type")
  isActive          Boolean?             @default(true) @map("is_active")
  config            Json?
  createdAt         DateTime?            @default(now()) @map("created_at")
  contextWindow     Int?                 @map("context_window")
  maxTokens         Int?                 @map("max_tokens")
  inputCostPer1k    Decimal?             @map("input_cost_per_1k") @db.Decimal
  outputCostPer1k   Decimal?             @map("output_cost_per_1k") @db.Decimal
  apiKey            String?              @map("api_key")
  generatedContents AIGeneratedContent[]
  usageLogs         AIUsageLog[]

  @@map("ai_models")
}

model AIPrompt {
  id                 BigInt               @id @default(autoincrement())
  promptKey          String               @unique @map("prompt_key")
  systemInstruction  String?              @map("system_instruction")
  userPromptTemplate String?              @map("user_prompt_template")
  moduleName         String?              @map("module_name")
  createdAt          DateTime?            @default(now()) @map("created_at")
  updatedAt          DateTime?            @default(now()) @map("updated_at")
  version            Int?                 @default(1)
  isActive           Boolean?             @default(true) @map("is_active")
  generatedContents  AIGeneratedContent[]

  @@map("ai_prompts")
}

model AIUsageLog {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  businessId   BigInt?   @map("business_id")
  modelId      BigInt?   @map("model_id")
  requestType  String    @map("request_type")
  tokensUsed   Int?      @default(0) @map("tokens_used")
  usageDate    DateTime? @default(now()) @map("usage_date") @db.Date
  inputTokens  Int?      @default(0) @map("input_tokens")
  outputTokens Int?      @default(0) @map("output_tokens")
  cost         Decimal?  @default(0) @db.Decimal
  business     Business? @relation(fields: [businessId], references: [id])
  model        AIModel?  @relation(fields: [modelId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@map("ai_usage_logs")
}

model AppConfig {
  id                 BigInt    @id @default(autoincrement())
  appName            String    @map("app_name")
  maintenanceMode    Boolean?  @default(false) @map("maintenance_mode")
  maintenanceMessage String?   @map("maintenance_message")
  developerMode      Boolean?  @default(false) @map("developer_mode")
  globalAiEnabled    Boolean?  @default(true) @map("global_ai_enabled")
  apiBaseUrl         String?   @map("api_base_url")
  supportEmail       String?   @map("support_email")
  createdAt          DateTime? @default(now()) @map("created_at")
  updatedAt          DateTime? @default(now()) @map("updated_at")
  freeTrialDays      Int?      @default(7) @map("free_trial_days")
  adminPanelUrl      String?   @map("admin_panel_url")
  landingPageUrl     String?   @map("landing_page_url")
  featuresJson       Json?     @map("features_json")
  heroSubtitle       String?   @map("hero_subtitle")
  heroTitle          String?   @map("hero_title")
  pricingTitle       String?   @map("pricing_title")
  primaryColor       String?   @default("#2ECC71") @map("primary_color")
  primaryColor       String?   @default("#2ECC71") @map("primary_color")

  @@map("app_configs")
}

model AppFeatureFlag {
  id         BigInt    @id @default(autoincrement())
  moduleName String    @map("module_name")
  featureKey String    @map("feature_key")
  isEnabled  Boolean?  @default(true) @map("is_enabled")
  createdAt  DateTime? @default(now()) @map("created_at")

  @@unique([moduleName, featureKey])
  @@map("app_feature_flags")
}

model AppPlatformConfig {
  id                     BigInt    @id @default(autoincrement())
  platform               String    @unique
  appVersion             String    @map("app_version")
  appVersionCode         Int       @map("app_version_code")
  forceUpdateVersion     String?   @map("force_update_version")
  forceUpdateVersionCode Int?      @map("force_update_version_code")
  storeUrl               String?   @map("store_url")
  updateDescription      String?   @map("update_description")
  createdAt              DateTime? @default(now()) @map("created_at")
  updatedAt              DateTime? @default(now()) @map("updated_at")

  @@map("app_platform_configs")
}

model AppTranslation {
  id           BigInt     @id @default(autoincrement())
  languageCode String     @unique @map("language_code")
  countryCode  String?    @map("country_code")
  displayName  String?    @map("display_name")
  isDefault    Boolean?   @default(false) @map("is_default")
  translations Json
  isActive     Boolean?   @default(true) @map("is_active")
  createdAt    DateTime?  @default(now()) @map("created_at")
  updatedAt    DateTime?  @default(now()) @map("updated_at")
  mediaId      BigInt?    @map("media_id")
  media        MediaFile? @relation("TranslationFlag", fields: [mediaId], references: [id])

  @@map("app_translations")
}

model ExternalServiceConfig {
  id        BigInt   @id @default(autoincrement())
  category  String
  provider  String
  config    Json
  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([category, provider])
  @@map("external_service_configs")
}

model MediaFile {
  id                          BigInt               @id @default(autoincrement())
  userId                      BigInt?              @map("user_id")
  businessId                  BigInt?              @map("business_id")
  fileUrl                     String               @map("file_url")
  fileType                    String               @map("file_type")
  mimeType                    String?              @map("mime_type")
  mediaCategory               String?              @map("media_category")
  relatedType                 String?              @map("related_type")
  relatedId                   BigInt?              @map("related_id")
  size                        Int?
  tags                        Json?
  createdAt                   DateTime             @default(now()) @map("created_at")
  aiGeneratedContents         AIGeneratedContent[]
  themesWithThisImage         AppTheme[]           @relation("ThemeImage")
  translationsWithThisFlag    AppTranslation[]     @relation("TranslationFlag")
  businessesWithThisLogo      Business[]           @relation("BusinessLogo")
  business                    Business?            @relation(fields: [businessId], references: [id])
  user                        User?                @relation("UserUploads", fields: [userId], references: [id])
  notificationsWithThisImage  Notifications[]      @relation("NotificationImage")
  paymentMethodsWithThisImage PaymentMethod[]      @relation("PaymentImage")
  platformsWithThisLogo       Platform[]           @relation("PlatformLogo")
  productsWithThisImage       Product[]            @relation("ProductImage")
  servicesWithThisImage       Service[]            @relation("ServiceImage")
  usersWithThisImage          User[]               @relation("UserProfileImage")

  @@map("media_files")
}

model AudienceType {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique
  isActive   Boolean?   @default(true) @map("is_active")
  businesses Business[]

  @@map("audience_types")
}

model BusinessType {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique
  isActive   Boolean?   @default(true) @map("is_active")
  businesses Business[]

  @@map("business_types")
}

model Business {
  id                 BigInt             @id @default(autoincrement())
  ownerId            BigInt             @map("user_id")
  name               String
  tagline            String?
  phone              String?
  email              String?
  website            String?
  address            String?
  country            String?
  state              String?
  city               String?
  brandColor         String?            @map("brand_color")
  description        String?
  audienceTypeId     BigInt?            @map("audience_type_id")
  targetRegionId     BigInt?            @map("target_region_id")
  targetGender       String?            @default("all") @map("target_gender")
  targetAgeGroupId   BigInt?            @map("target_age_group_id")
  modelEthnicityId   BigInt?            @map("model_ethnicity_id")
  createdAt          DateTime?          @default(now()) @map("created_at")
  businessTypeId     BigInt?            @map("business_type_id")
  ctaButtonId        BigInt?            @map("cta_button_id")
  mediaId            BigInt?            @map("media_id")
  postalCode         String?            @map("postal_code")
  updatedAt          DateTime?          @default(now()) @map("updated_at")
  visibilityStatus   String?            @default("active") @map("visibility_status")
  usageLogs          AIUsageLog[]
  businessCategories BusinessCategory[]
  audienceType       AudienceType?      @relation(fields: [audienceTypeId], references: [id])
  businessType       BusinessType?      @relation(fields: [businessTypeId], references: [id])
  ctaButton          CTAButton?         @relation(fields: [ctaButtonId], references: [id])
  media              MediaFile?         @relation("BusinessLogo", fields: [mediaId], references: [id])
  modelEthnicity     ModelEthnicity?    @relation(fields: [modelEthnicityId], references: [id])
  targetAgeGroup     TargetAgeGroup?    @relation(fields: [targetAgeGroupId], references: [id])
  targetRegion       TargetRegion?      @relation(fields: [targetRegionId], references: [id])
  owner              User               @relation(fields: [ownerId], references: [id])
  mediaFiles         MediaFile[]
  products           Product[]
  services           Service[]
  socialAccounts     SocialAccount[]

  @@map("businesses")
}

model BusinessCategory {
  id         BigInt    @id @default(autoincrement())
  businessId BigInt    @map("business_id")
  categoryId BigInt    @map("category_id")
  createdAt  DateTime? @default(now()) @map("created_at")
  business   Business  @relation(fields: [businessId], references: [id])
  category   Category  @relation(fields: [categoryId], references: [id])

  @@map("business_categories")
}

model Category {
  id                 BigInt             @id @default(autoincrement())
  name               String
  isActive           Boolean?           @default(true) @map("is_active")
  type               String             @default("business") @db.VarChar(50)
  businessCategories BusinessCategory[]
  productCategories  ProductCategory[]
  serviceCategories  ServiceCategory[]
  subCategories      SubCategory[]

  @@unique([name, type])
  @@index([type])
  @@map("categories")
}

model CTAButton {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique
  isActive   Boolean?   @default(true) @map("is_active")
  businesses Business[]

  @@map("cta_buttons")
}

model Currency {
  id           BigInt    @id @default(autoincrement())
  name         String?
  code         String?   @unique
  symbol       String?
  exchangeRate Decimal?  @map("exchange_rate") @db.Decimal
  status       Boolean?  @default(true)
  createdAt    DateTime? @default(now()) @map("created_at")
  isDefault    Boolean?  @default(false) @map("is_default")
  users        User[]

  @@map("currencies")
}

model DeviceToken {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @map("user_id")
  deviceId     String    @map("device_id")
  deviceType   String?   @map("device_type")
  fcmToken     String?   @map("fcm_token")
  isActive     Boolean?  @default(true) @map("is_active")
  createdAt    DateTime? @default(now()) @map("created_at")
  lastLoggedIn DateTime? @default(now()) @map("last_logged_in")
  tokenVersion Int       @default(1) @map("token_version")
  user         User      @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
  @@map("device_tokens")
}

model Feedback {
  id        BigInt    @id @default(autoincrement())
  message   String
  rating    Int?      @default(5)
  type      String?   @default("general")
  status    String?   @default("pending")
  createdAt DateTime? @default(now()) @map("created_at")
  subject   String?
  userId    BigInt?   @map("user_id")
  user      User?     @relation(fields: [userId], references: [id])

  @@map("feedbacks")
}

model ModelEthnicity {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique
  isActive   Boolean?   @default(true) @map("is_active")
  businesses Business[]

  @@map("model_ethnicities")
}

model Notifications {
  id        BigInt     @id @default(autoincrement())
  title     String
  message   String
  type      String?    @default("general")
  actionUrl String?    @map("action_url")
  isGlobal  Boolean?   @default(false) @map("is_global")
  createdAt DateTime?  @default(now()) @map("created_at")
  mediaId   BigInt?    @map("media_id")
  media     MediaFile? @relation("NotificationImage", fields: [mediaId], references: [id])

  @@map("notifications")
}

model PaymentMethod {
  id          BigInt     @id @default(autoincrement())
  name        String     @unique
  displayName String?    @map("display_name")
  type        String
  config      Json?
  mode        String     @default("test")
  isActive    Boolean?   @default(true) @map("is_active")
  isDefault   Boolean?   @default(false) @map("is_default")
  createdAt   DateTime?  @default(now()) @map("created_at")
  mediaId     BigInt?    @map("media_id")
  media       MediaFile? @relation("PaymentImage", fields: [mediaId], references: [id])

  @@map("payment_methods")
}

model Platform {
  id             BigInt          @id @default(autoincrement())
  name           String          @unique
  url            String?
  nameKey        String?         @unique @map("name_key")
  appId          String?         @map("app_id")
  appSecret      String?         @map("app_secret")
  clientToken    String?         @map("client_token")
  isActive       Boolean?        @default(true) @map("is_active")
  mediaId        BigInt?         @map("media_id")
  media          MediaFile?      @relation("PlatformLogo", fields: [mediaId], references: [id])
  socialAccounts SocialAccount[]

  @@map("platforms")
}

model ProductCategory {
  id         BigInt    @id @default(autoincrement())
  productId  BigInt    @map("product_id")
  categoryId BigInt    @map("category_id")
  createdAt  DateTime? @default(now()) @map("created_at")
  category   Category  @relation(fields: [categoryId], references: [id])
  product    Product   @relation(fields: [productId], references: [id])

  @@map("product_categories")
}

model ProductSubCategory {
  id            BigInt      @id @default(autoincrement())
  productId     BigInt      @map("product_id")
  subCategoryId BigInt      @map("sub_category_id")
  createdAt     DateTime?   @default(now()) @map("created_at")
  product       Product     @relation(fields: [productId], references: [id])
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])

  @@map("product_sub_categories")
}

model Product {
  id                   BigInt               @id @default(autoincrement())
  businessId           BigInt               @map("business_id")
  name                 String
  description          String?
  price                Decimal              @default(0) @db.Decimal
  stock                Int?                 @default(0)
  tags                 Json?
  visibilityStatus     String?              @default("active") @map("visibility_status")
  createdAt            DateTime?            @default(now()) @map("created_at")
  updatedAt            DateTime?            @default(now()) @map("updated_at")
  mediaId              BigInt?              @map("media_id")
  productCategories    ProductCategory[]
  productSubCategories ProductSubCategory[]
  business             Business             @relation(fields: [businessId], references: [id])
  media                MediaFile?           @relation("ProductImage", fields: [mediaId], references: [id])

  @@map("products")
}

model Role {
  id        BigInt    @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime? @default(now()) @map("created_at")
  isActive  Boolean   @default(true) @map("is_active")
  users     User[]

  @@map("roles")
}

model ServiceCategory {
  id         BigInt   @id @default(autoincrement())
  serviceId  BigInt   @map("service_id")
  categoryId BigInt   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])

  @@map("service_categories")
}

model ServiceSubCategory {
  id            BigInt      @id @default(autoincrement())
  serviceId     BigInt      @map("service_id")
  subCategoryId BigInt      @map("sub_category_id")
  createdAt     DateTime?   @default(now()) @map("created_at")
  service       Service     @relation(fields: [serviceId], references: [id])
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])

  @@map("service_sub_categories")
}

model Service {
  id                   BigInt               @id @default(autoincrement())
  businessId           BigInt               @map("business_id")
  name                 String
  description          String?
  price                Decimal              @default(0) @db.Decimal
  slots                Int?                 @default(1)
  tags                 Json?
  visibilityStatus     String?              @default("active") @map("visibility_status")
  createdAt            DateTime?            @default(now()) @map("created_at")
  updatedAt            DateTime?            @default(now()) @map("updated_at")
  mediaId              BigInt?              @map("media_id")
  serviceCategories    ServiceCategory[]
  serviceSubCategories ServiceSubCategory[]
  business             Business             @relation(fields: [businessId], references: [id])
  media                MediaFile?           @relation("ServiceImage", fields: [mediaId], references: [id])

  @@map("services")
}

model SocialAccount {
  id           BigInt    @id @default(autoincrement())
  businessId   BigInt    @map("business_id")
  platformId   BigInt    @map("platform_id")
  accountName  String?   @map("account_name")
  accountId    String?   @unique @map("account_id")
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  createdAt    DateTime? @default(now()) @map("created_at")
  isActive     Boolean?  @default(true) @map("is_active")
  business     Business  @relation(fields: [businessId], references: [id])
  platform     Platform  @relation(fields: [platformId], references: [id])

  @@map("social_accounts")
}

model StaticPage {
  id        BigInt    @id @default(autoincrement())
  slug      String    @unique
  title     String
  content   String?
  isActive  Boolean?  @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @map("updated_at")

  @@map("static_pages")
}

model SubCategory {
  id                   BigInt               @id @default(autoincrement())
  categoryId           BigInt               @map("category_id")
  name                 String
  createdAt            DateTime?            @default(now()) @map("created_at")
  isActive             Boolean?             @default(true) @map("is_active")
  type                 String               @default("business") @db.VarChar(50)
  productSubCategories ProductSubCategory[]
  serviceSubCategories ServiceSubCategory[]
  category             Category             @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, type, name])
  @@index([type])
  @@index([categoryId, type])
  @@map("sub_categories")
}

model SubscriptionPermission {
  id            BigInt    @id @default(autoincrement())
  tierKey       String    @map("tier_key")
  permissionKey String    @map("permission_key")
  createdAt     DateTime? @default(now()) @map("created_at")

  @@unique([tierKey, permissionKey])
  @@map("subscription_permissions")
}

model SubscriptionTier {
  id                BigInt             @id @default(autoincrement())
  tierKey           String             @unique @map("tier_key")
  name              String
  priceAmount       Decimal?           @default(0) @map("price_amount") @db.Decimal
  pricePeriod       String?            @default("month") @map("price_period")
  badge             String?
  highlightFeatures Json?              @map("highlight_features")
  limits            Json?
  isActive          Boolean?           @default(true) @map("is_active")
  createdAt         DateTime?          @default(now()) @map("created_at")
  updatedAt         DateTime?          @default(now()) @map("updated_at")
  loginDeviceLimit  BigInt?            @default(1) @map("login_device_limit")
  subscriptionLimit BigInt?            @default(1) @map("subscription_limit")
  userSubscriptions UserSubscription[]

  @@map("subscription_tiers")
}

model TargetAgeGroup {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique
  isActive   Boolean?   @default(true) @map("is_active")
  businesses Business[]

  @@map("target_age_groups")
}

model TargetRegion {
  id         BigInt     @id @default(autoincrement())
  name       String     @unique
  isActive   Boolean?   @default(true) @map("is_active")
  businesses Business[]

  @@map("target_regions")
}

model UserBlock {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  blockedBy BigInt    @map("blocked_by")
  reason    String?
  status    Boolean
  createdAt DateTime? @default(now()) @map("created_at")
  blocker   User      @relation("UserToUserBlockBlocker", fields: [blockedBy], references: [id])
  user      User      @relation("UserToUserBlockUser", fields: [userId], references: [id])

  @@map("user_blocks")
}

model UserSubscription {
  id        BigInt           @id @default(autoincrement())
  userId    BigInt           @map("user_id")
  tierKey   String           @map("tier_key")
  startDate DateTime?        @default(now()) @map("start_date")
  endDate   DateTime?        @map("end_date")
  status    String?          @default("active")
  createdAt DateTime?        @default(now()) @map("created_at")
  tier      SubscriptionTier @relation(fields: [tierKey], references: [tierKey])
  user      User             @relation(fields: [userId], references: [id])

  @@map("user_subscriptions")
}

model User {
  id                BigInt               @id @default(autoincrement())
  name              String?
  phone             String?              @unique
  email             String?              @unique
  createdAt         DateTime?            @default(now()) @map("created_at")
  updatedAt         DateTime?            @default(now()) @map("updated_at")
  currencyCode      String?              @map("currency_code")
  roleId            BigInt?              @map("role_id")
  dob               DateTime?            @db.Date
  bio               String?
  pushEnabled       Boolean?             @default(true) @map("push_enabled")
  emailEnabled      Boolean?             @default(true) @map("email_enabled")
  smsEnabled        Boolean?             @default(false) @map("sms_enabled")
  whatsappEnabled   Boolean?             @default(false) @map("whatsapp_enabled")
  isDeleted         Boolean?             @default(false) @map("is_deleted")
  deletedAt         DateTime?            @map("deleted_at")
  password          String?
  isVerified        Boolean?             @default(false) @map("is_verified")
  mediaId           BigInt?              @map("media_id")
  appleId           String?              @unique @map("apple_id")
  googleId          String?              @unique @map("google_id")
  generatedContents AIGeneratedContent[]
  usageLogs         AIUsageLog[]
  businesses        Business[]
  deviceTokens      DeviceToken[]
  feedbacks         Feedback[]
  mediaFiles        MediaFile[]          @relation("UserUploads")
  blockedUsers      UserBlock[]          @relation("UserToUserBlockBlocker")
  blocks            UserBlock[]          @relation("UserToUserBlockUser")
  userSubscriptions UserSubscription[]
  currency          Currency?            @relation(fields: [currencyCode], references: [code])
  profileMedia      MediaFile?           @relation("UserProfileImage", fields: [mediaId], references: [id])
  role              Role?                @relation(fields: [roleId], references: [id])

  @@map("users")
}

model AppTheme {
  id                 BigInt     @id @default(autoincrement())
  name               String
  primaryColor       String     @map("primary_color")
  secondaryColor     String     @map("secondary_color")
  darkPrimaryColor   String     @map("dark_primary_color")
  darkSecondaryColor String     @map("dark_secondary_color")
  isDefault          Boolean?   @default(false) @map("is_default")
  createdAt          DateTime?  @default(now()) @map("created_at")
  isActive           Boolean?   @default(true) @map("is_active")
  mediaId            BigInt?    @map("media_id")
  media              MediaFile? @relation("ThemeImage", fields: [mediaId], references: [id])

  @@map("app_themes")
}

model OtpVerification {
  id        BigInt   @id @default(autoincrement())
  phone     String?
  email     String?
  otp       String
  expiry    DateTime
  createdAt DateTime @default(now()) @map("created_at")

